program "QuaternionRotation"

define quat called "identityRot" be identity
define quat called "rot" be quat from axis [0, 0, 1] angle 90 deg
define quat called "mid" be identity
define vec3 called "out" be [0, 0, 0]
define vec3 called "e" be [0, 0, 0]

set "out" to rotate vector [1, 0, 0] by "rot"
print "out"

set "mid" to slerp "identityRot", "rot", 0.5
print "mid"

set "e" to euler from quat "rot"
print "e"

blend mix to code 0

end program "QuaternionRotation"
