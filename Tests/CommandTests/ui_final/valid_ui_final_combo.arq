program "ValidUiFinalCombo"
set title to string "M19 UI Final"

define int called "score" be 0
define bool called "menuVisible" be true

define style called "PrimaryButton"
    background color: blue
    foreground color: white
    corner radius: 8 px
end style

define texture called "ButtonTexture" from file "ui/button.png"
define sound called "ClickSound" from file "audio/click.wav"

define shape called "Menu"
define text called "ScoreText"
define button called "PlayButton"

parent "ScoreText" to "Menu"
parent "PlayButton" to "Menu"

with layout for "Menu"
    mode: flex
    direction: vertical
    gap: 8 px
end layout

use style "PrimaryButton" for "PlayButton"
set texture of "PlayButton" to "ButtonTexture"
set sound of "PlayButton" to "ClickSound"
link "ScoreText" content to "score"
link "Menu" visible to "menuVisible"
set state of "PlayButton" to default

when clicked "PlayButton"
    print string "Play"
end when

show string "ui final combo"
blend mix to code 0
end program "ValidUiFinalCombo"
