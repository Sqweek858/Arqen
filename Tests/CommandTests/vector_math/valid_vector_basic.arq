program "VectorBasic"

define vec2 called "a" be [1, 2]
define vec2 called "b" be [3, 4]
define vec2 called "c" be [0, 0]

set "c" to "a" + "b"
print "c"

set "c" to "b" - "a"
print "c"

set "c" to "a" * 2
print "c"

set "c" to 3 * "a"
print "c"

set "c" to "b" / 2
print "c"

blend mix to code 0

end program "VectorBasic"
