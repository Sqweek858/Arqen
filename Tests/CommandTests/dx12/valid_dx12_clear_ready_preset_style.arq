program "ValidDx12ClearReadyPresetStyle"
set title to string "M20D DX12"

define window called "MainWindow"
define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"

define style called "RendererClear"
    background color: color "#203040"
end style

use style "RendererClear" for "MainRenderer"

show message "dx12 clear ready preset"
blend mix to code 0
end program "ValidDx12ClearReadyPresetStyle"
