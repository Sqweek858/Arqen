program "ValidDx12MixedReadyAndMetadataRenderers"
set title to string "M20D DX12"

define window called "MainWindow"
define dx12 renderer called "MainRenderer"
define dx12 renderer called "OverlayRenderer"
parent renderer "MainRenderer" to window "MainWindow"

with style for "MainRenderer"
    background color: color "#101820"
end style

with style for "OverlayRenderer"
    background color: color "#201020"
end style

show message "dx12 mixed ready and metadata renderers"
blend mix to code 0
end program "ValidDx12MixedReadyAndMetadataRenderers"
