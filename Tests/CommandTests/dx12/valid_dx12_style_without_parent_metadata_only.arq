program "ValidDx12StyleWithoutParentMetadataOnly"
set title to string "M20D DX12"

define dx12 renderer called "MainRenderer"

with style for "MainRenderer"
    background color: color "#101820"
end style

show message "dx12 style without parent metadata only"
blend mix to code 0
end program "ValidDx12StyleWithoutParentMetadataOnly"
