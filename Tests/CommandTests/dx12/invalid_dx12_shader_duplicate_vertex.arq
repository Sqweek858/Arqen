program "InvalidDx12ShaderDuplicateVertex"
set title to string "M21B DX12"

define shader called "TriangleShader"
    vertex source file "Shaders/triangle_vs.hlsl"
    vertex source file "Shaders/other_vs.hlsl"
    pixel source file "Shaders/triangle_ps.hlsl"
end shader

show message "bad"
blend mix to code 0
end program "InvalidDx12ShaderDuplicateVertex"
