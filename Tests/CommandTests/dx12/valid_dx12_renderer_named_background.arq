program "ValidDx12RendererNamedBackground"
set title to string "M20C DX12"

define window called "MainWindow"
define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"

with style for "MainRenderer"
    background color: emerald
end style

show message "dx12 renderer named clear style"
blend mix to code 0
end program "ValidDx12RendererNamedBackground"
