program "ValidDx12RendererWithStyleBackground"
set title to string "M20B DX12"

define window called "MainWindow"
define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"

with style for "MainRenderer"
    background color: color "#101820"
end style

show message "dx12 renderer style background"
blend mix to code 0
end program "ValidDx12RendererWithStyleBackground"
