program "InvalidDx12MouseButtonBadButton"
set title to string "invalid dx12 mouse button bad button"

define window called "MainWindow"
define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"
define camera called "MainCamera"
use camera "MainCamera" for renderer "MainRenderer"

when mouse button "Side" is held move camera "MainCamera" by [0.0, 0.0, 1.0]

show message "invalid dx12 mouse button bad button"
blend mix to code 0
end program "InvalidDx12MouseButtonBadButton"
