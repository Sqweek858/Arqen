program "InvalidDx12RendererStyleDuplicateClearSources"
set title to string "M20C DX12"

define dx12 renderer called "MainRenderer"

with style for "MainRenderer"
    background color: color "#101820"
end style

define style called "RendererClear"
    background color: color "#203040"
end style

use style "RendererClear" for "MainRenderer"

show message "bad"
blend mix to code 0
end program "InvalidDx12RendererStyleDuplicateClearSources"
