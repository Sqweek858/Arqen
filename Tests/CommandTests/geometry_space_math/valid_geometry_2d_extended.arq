program "Geometry2DExtended"


define segment called "a" be segment from [0, 0] to [10, 0]
define segment called "b" be segment from [5, -5] to [5, 5]
define line called "floor" be line from [0, 0] to [10, 0]
define rect called "r" be rect [0, 0] size [10, 10]
define circle called "c" be circle center [10, 5] radius 3
define bool called "hit" be false
define vec2 called "p" be [0, 0]
define double called "d" be 0

set "hit" to segment "a" intersects "b"
print "hit"

set "p" to closest point on segment "a" to [15, 2]
print "p"

set "d" to distance from point [0, 3] to line "floor"
print "d"

set "d" to distance from point [15, 4] to segment "a"
print "d"

set "hit" to rect "r" intersects "c"
print "hit"


blend mix to code 0

end program "Geometry2DExtended"
