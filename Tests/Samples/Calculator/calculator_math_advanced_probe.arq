program "CalculatorMathAdvancedProbe"

set title to string "Arqen Advanced Math Probe"

print string "=============================="
print string "ARQEN ADVANCED MATH PROBE"
print string "=============================="

define double called "x" be 0
define int called "i" be 0
define vec3 called "v3" be [0, 0, 0]
define vec3 called "axisX" be [1, 0, 0]
define vec3 called "axisY" be [0, 1, 0]

print string "Scalar math"

set "x" to sqrt 144
print "x"

set "x" to abs -42
print "x"

set "i" to floor 9.8
print "i"

set "i" to ceil 9.1
print "i"

set "i" to round 9.5
print "i"

set "x" to min 12, 4
print "x"

set "x" to max 12, 4
print "x"

set "x" to clamp 250 between 0 and 100
print "x"

set "x" to sin 0
print "x"

set "x" to cos 0
print "x"

set "x" to pow 2, 8
print "x"

print string "Interpolation"

set "x" to lerp 10, 20, 0.5
print "x"

set "x" to remap 50 from 0, 100 to 0, 1
print "x"

set "x" to smoothstep 0, 1, 0.5
print "x"

print string "Vector math"

set "x" to length [3, 4]
print "x"

set "x" to dot [1, 2], [3, 4]
print "x"

set "x" to length [2, 3, 6]
print "x"

set "x" to dot [1, 2, 3], [4, 5, 6]
print "x"

set "v3" to cross "axisX", "axisY"
print "v3"

set "v3" to normalize [0, 3, 4]
print "v3"

set "v3" to lerp [0, 0, 0], [10, 20, 30], 0.5
print "v3"

print string "Geometry distance"

set "x" to distance [0, 0], [3, 4]
print "x"

print string "Coordinate conversion"

set "x" to radians from degrees 180
print "x"

set "x" to degrees from radians 3.1415926535
print "x"

print string "FINAL RESULT: SAMPLE COMPILED"

blend mix to code 0

end program "CalculatorMathAdvancedProbe"

