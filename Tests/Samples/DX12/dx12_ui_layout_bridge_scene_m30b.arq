program "Dx12UiLayoutBridgeSceneM30B"
set title to string "Arqen M30B UI Layout Bridge"

// M30B/M30C official scene:
// - carries the M29C 3D scene forward
// - draws UI panel/text/buttons/switches through the DX12 runtime overlay bridge
// - AnimationSwitch toggles color animation
// - LightSwitch toggles fake directional lighting
// - no docking editor, font loading, text input, sliders, dropdown popups, textures, blur, or drag/drop

define window called "MainWindow"
set title of "MainWindow" to string "Arqen M30B UI Layout Bridge"
set resolution of "MainWindow" to 1280 x 720

define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"

with style for "MainWindow"
    title bar color: color "#000000"
    title text color: color "#FFFFFF"
end style

with style for "MainRenderer"
    background color: color "#02030A"
end style

define shader called "BoxShader"
    vertex source file "Samples/DX12/Shaders/triangle_vs.hlsl"
    pixel source file "Samples/DX12/Shaders/triangle_tint_ps.hlsl"
end shader

define dx12 pipeline called "BoxPipeline"
    renderer: "MainRenderer"
    shader: "BoxShader"
    topology: triangle list
end pipeline

use pipeline "BoxPipeline" for renderer "MainRenderer"

define constant buffer called "SceneParams"
    color tint: color "#D8FFF4"
end constant buffer
use constant buffer "SceneParams" for pipeline "BoxPipeline"

define camera called "MainCamera"
use camera "MainCamera" for renderer "MainRenderer"
set camera "MainCamera" projection to perspective
set position of camera "MainCamera" to [0.0, 0.0, -6.0]
set rotation of camera "MainCamera" to [0.0, 0.0, 0.0]
set field of view of camera "MainCamera" to 70 deg
set near plane of camera "MainCamera" to 0.1
set far plane of camera "MainCamera" to 100.0

capture mouse for window "MainWindow"
when mouse moves rotate camera "MainCamera" by [0.10, 0.10]
when mouse wheel moves move camera "MainCamera" by [0.0, 0.0, 1.0]
when key "W" is held move camera "MainCamera" by [0.0, 0.0, 3.0]
when key "S" is held move camera "MainCamera" by [0.0, 0.0, -3.0]
when key "A" is held move camera "MainCamera" by [-3.0, 0.0, 0.0]
when key "D" is held move camera "MainCamera" by [3.0, 0.0, 0.0]
when key "Q" is held move camera "MainCamera" by [0.0, -3.0, 0.0]
when key "E" is held move camera "MainCamera" by [0.0, 3.0, 0.0]

define object selector called "PrimarySelector"
use object selector "PrimarySelector" for renderer "MainRenderer"
when mouse button "Left" is pressed select object using "PrimarySelector"
when key "R" is held rotate selected object around y by mouse x sensitivity 0.35

define color sequence called "PulseSequence"
    color "#D8FFF4"
    color "#8FE8FF"
    color "#CBA6FF"
end color sequence

animate color "SceneParams.tint"
    using sequence "PulseSequence"
    every 30 frames
end animate

define directional light called "KeyLight"
use light "KeyLight" for renderer "MainRenderer"
set direction of light "KeyLight" to [-0.35, -0.70, -0.60]
set intensity of light "KeyLight" to 0.95
set ambient of light "KeyLight" to 0.16

define box called "CubeA"
use renderer "MainRenderer" for object "CubeA"
use pipeline "BoxPipeline" for object "CubeA"
set position of object "CubeA" to [-1.35, -0.05, 2.7]
set rotation of object "CubeA" to [18.0, 35.0, 12.0]
set scale of object "CubeA" to [1.0, 1.0, 1.0]

define box called "CubeB"
use renderer "MainRenderer" for object "CubeB"
use pipeline "BoxPipeline" for object "CubeB"
set position of object "CubeB" to [1.20, -0.20, 4.2]
set rotation of object "CubeB" to [-12.0, 48.0, -22.0]
set scale of object "CubeB" to [0.85, 0.85, 0.85]

define box called "CubeC"
use renderer "MainRenderer" for object "CubeC"
use pipeline "BoxPipeline" for object "CubeC"
set position of object "CubeC" to [0.05, 1.05, 5.9]
set rotation of object "CubeC" to [35.0, -20.0, 42.0]
set scale of object "CubeC" to [0.55, 0.55, 0.55]

define box called "CubeD"
use renderer "MainRenderer" for object "CubeD"
use pipeline "BoxPipeline" for object "CubeD"
set position of object "CubeD" to [-2.20, 0.65, 7.0]
set rotation of object "CubeD" to [-20.0, -32.0, 15.0]
set scale of object "CubeD" to [0.70, 0.70, 0.70]

// UI overlay: existing M19 style/layout/object metadata rendered by M30B/M30C DX12 bridge.
// No new public syntax: parent-relative layout, clip children, padding, z index, and text fit are runtime/lowerer wiring.
define shape called "InspectorPanel"
define text called "PanelTitle"
define text called "HintText"
define text called "ToolText"
define checkbox called "AnimationSwitch"
define checkbox called "LightSwitch"
define button called "AnimationButton"

parent "PanelTitle" to "InspectorPanel"
parent "HintText" to "InspectorPanel"
parent "ToolText" to "InspectorPanel"
parent "AnimationSwitch" to "InspectorPanel"
parent "LightSwitch" to "InspectorPanel"
parent "AnimationButton" to "InspectorPanel"

set content of "PanelTitle" to string "ARQEN DX12 SANDBOX"
set content of "HintText" to string "RMB FLY | LMB SELECT"
set content of "ToolText" to string "R + MOUSE: ROTATE"
set content of "AnimationSwitch" to string "ANIMATION"
set checked of "AnimationSwitch" to true
set content of "LightSwitch" to string "FAKE LIGHT"
set checked of "LightSwitch" to true
set content of "AnimationButton" to string "TOGGLE ANIM"

with layout for "InspectorPanel"
    x: 16 px
    y: 16 px
    width: 420 px
    height: 244 px
end layout

with layout for "PanelTitle"
    x: 0 px
    y: 0 px
    width: 372 px
    height: 26 px
end layout

with layout for "HintText"
    x: 0 px
    y: 34 px
    width: 372 px
    height: 22 px
end layout

with layout for "ToolText"
    x: 0 px
    y: 62 px
    width: 372 px
    height: 22 px
end layout

with layout for "AnimationSwitch"
    x: 0 px
    y: 106 px
    width: 210 px
    height: 34 px
end layout

with layout for "LightSwitch"
    x: 0 px
    y: 150 px
    width: 210 px
    height: 34 px
end layout

with layout for "AnimationButton"
    x: 232 px
    y: 106 px
    width: 140 px
    height: 78 px
end layout

with style for "InspectorPanel"
    background color: color "#101820"
    border color: color "#39D5FF"
    border size: 2 px
    opacity: 0.82
    padding: 18 px
    clip children: true
    overflow: hidden
    z index: 10
end style

with style for "PanelTitle"
    foreground color: color "#E8FFFF"
    size: 20 px
    z index: 11
end style

with style for "HintText"
    foreground color: color "#9BE7FF"
    size: 15 px
    z index: 11
end style

with style for "ToolText"
    foreground color: color "#9BE7FF"
    size: 15 px
    z index: 11
end style

with style for "AnimationSwitch"
    background color: color "#18384A"
    foreground color: color "#E8FFFF"
    border color: color "#39D5FF"
    border size: 1 px
    padding: 8 px
    size: 16 px
    z index: 12
end style

with style for "LightSwitch"
    background color: color "#18384A"
    foreground color: color "#E8FFFF"
    border color: color "#39D5FF"
    border size: 1 px
    padding: 8 px
    size: 16 px
    z index: 12
end style

with style for "AnimationButton"
    background color: color "#2A2048"
    foreground color: color "#F3E8FF"
    border color: color "#CBA6FF"
    border size: 1 px
    padding: 10 px
    size: 16 px
    z index: 12
end style

when clicked "AnimationSwitch"
    print string "toggle animation"
end when

when clicked "LightSwitch"
    print string "toggle light"
end when

when clicked "AnimationButton"
    print string "toggle animation"
end when

begin frame of "MainRenderer"
clear renderer "MainRenderer"
draw "CubeA"
draw "CubeB"
draw "CubeC"
draw "CubeD"
end frame of "MainRenderer"
present frame of "MainRenderer"

show message "M30B/M30C: DX12 UI overlay uses parent-relative layout, clipping, centered button text, and clean controls"
blend mix to code 0
end program "Dx12UiLayoutBridgeSceneM30B"
