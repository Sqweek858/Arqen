program "Dx12MultiObjectSceneM23C"
set title to string "Arqen M23C Multi Object Scene"

// M23A/B/C real scene object sample.
// Public syntax target:
//   define object called "CrystalA"
//   draw "CrystalA"

define window called "MainWindow"
set title of "MainWindow" to string "Arqen M23C Multi Object Scene"
set resolution of "MainWindow" to 1280 x 720
show window "MainWindow"

define dx12 renderer called "MainRenderer"
parent renderer "MainRenderer" to window "MainWindow"

with style for "MainRenderer"
    background color: color "#07111C"
end style

define shader called "TriangleShader"
    vertex source file "Samples/DX12/Shaders/triangle_vs.hlsl"
    pixel source file "Samples/DX12/Shaders/triangle_tint_ps.hlsl"
end shader

define dx12 pipeline called "CrystalPipeline"
    renderer: "MainRenderer"
    shader: "TriangleShader"
    topology: triangle list
end pipeline

use pipeline "CrystalPipeline" for renderer "MainRenderer"

define vertex buffer called "CrystalAVertices"
    vertex position [-0.390, 0.479, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.426, 0.049, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [-0.520, 0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [-0.426, 0.049, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.650, -0.319, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [-0.520, 0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [-0.650, -0.319, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.614, 0.111, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [-0.520, 0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [-0.614, 0.111, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.390, 0.479, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [-0.520, 0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
end vertex buffer

define vertex buffer called "CrystalBVertices"
    vertex position [-0.345, 0.163, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.167, -0.136, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [-0.240, -0.160, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [-0.167, -0.136, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.135, -0.483, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [-0.240, -0.160, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [-0.135, -0.483, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.313, -0.184, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [-0.240, -0.160, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [-0.313, -0.184, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.345, 0.163, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [-0.240, -0.160, 0.000] color [0.900, 0.800, 1.000, 1.000]
end vertex buffer

define vertex buffer called "CrystalCVertices"
    vertex position [0.060, 0.660, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.168, 0.180, 0.000] color [0.120, 1.000, 0.740, 1.000]
    vertex position [0.060, 0.180, 0.000] color [0.760, 1.000, 0.900, 1.000]
    vertex position [0.168, 0.180, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.060, -0.300, 0.000] color [0.120, 1.000, 0.740, 1.000]
    vertex position [0.060, 0.180, 0.000] color [0.760, 1.000, 0.900, 1.000]
    vertex position [0.060, -0.300, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [-0.048, 0.180, 0.000] color [0.120, 1.000, 0.740, 1.000]
    vertex position [0.060, 0.180, 0.000] color [0.760, 1.000, 0.900, 1.000]
    vertex position [-0.048, 0.180, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.060, 0.660, 0.000] color [0.120, 1.000, 0.740, 1.000]
    vertex position [0.060, 0.180, 0.000] color [0.760, 1.000, 0.900, 1.000]
end vertex buffer

define vertex buffer called "CrystalDVertices"
    vertex position [0.539, 0.238, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.442, -0.118, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [0.370, -0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [0.442, -0.118, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.201, -0.398, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [0.370, -0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [0.201, -0.398, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.298, -0.042, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [0.370, -0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
    vertex position [0.298, -0.042, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.539, 0.238, 0.000] color [0.240, 0.760, 1.000, 1.000]
    vertex position [0.370, -0.080, 0.000] color [0.800, 0.950, 1.000, 1.000]
end vertex buffer

define vertex buffer called "CrystalEVertices"
    vertex position [0.488, 0.480, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.677, 0.238, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [0.620, 0.210, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [0.677, 0.238, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.752, -0.060, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [0.620, 0.210, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [0.752, -0.060, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.563, 0.182, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [0.620, 0.210, 0.000] color [0.900, 0.800, 1.000, 1.000]
    vertex position [0.563, 0.182, 0.000] color [1.000, 1.000, 1.000, 1.000]
    vertex position [0.488, 0.480, 0.000] color [0.480, 0.360, 1.000, 1.000]
    vertex position [0.620, 0.210, 0.000] color [0.900, 0.800, 1.000, 1.000]
end vertex buffer

define constant buffer called "SceneParams"
    color tint: color "#38FFC0"
end constant buffer

use constant buffer "SceneParams" for pipeline "CrystalPipeline"

define color sequence called "ScenePulse"
    color "#38FFC0"
    color "#7C4DFF"
    color "#FF4FD8"
    color "#40A0FF"
    color "#F7FF7A"
end color sequence

animate color "SceneParams.tint"
    using sequence "ScenePulse"
    every 10 frames
end animate

define object called "CrystalA"
use renderer "MainRenderer" for object "CrystalA"
use pipeline "CrystalPipeline" for object "CrystalA"
use vertex buffer "CrystalAVertices" for object "CrystalA"
draw 12 vertices for object "CrystalA"

define object called "CrystalB"
use renderer "MainRenderer" for object "CrystalB"
use pipeline "CrystalPipeline" for object "CrystalB"
use vertex buffer "CrystalBVertices" for object "CrystalB"
draw 12 vertices for object "CrystalB"

define object called "CrystalC"
use renderer "MainRenderer" for object "CrystalC"
use pipeline "CrystalPipeline" for object "CrystalC"
use vertex buffer "CrystalCVertices" for object "CrystalC"
draw 12 vertices for object "CrystalC"

define object called "CrystalD"
use renderer "MainRenderer" for object "CrystalD"
use pipeline "CrystalPipeline" for object "CrystalD"
use vertex buffer "CrystalDVertices" for object "CrystalD"
draw 12 vertices for object "CrystalD"

define object called "CrystalE"
use renderer "MainRenderer" for object "CrystalE"
use pipeline "CrystalPipeline" for object "CrystalE"
use vertex buffer "CrystalEVertices" for object "CrystalE"
draw 12 vertices for object "CrystalE"

begin frame of "MainRenderer"
clear renderer "MainRenderer"
draw "CrystalA"
draw "CrystalB"
draw "CrystalC"
draw "CrystalD"
draw "CrystalE"
end frame of "MainRenderer"
present frame of "MainRenderer"

run window "MainWindow"
end program "Dx12MultiObjectSceneM23C"
